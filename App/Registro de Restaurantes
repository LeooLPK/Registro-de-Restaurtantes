use anchor_lang::prelude::*;

declare_id!("G2uGqU4SbrRdCZaCG4fTSVWHMTCEPMNwBgNZ4eLBCArj");

#[program]
pub mod registro_restaurantes {
    use super::*;

    pub fn create(
        ctx: Context<CreateRestaurante>,
        nombre: String,
        tipo_comida: String,
        ubicacion: String,
        calificacion: u8,
        precio_promedio: u32,
    ) -> Result<()> {
        let restaurante = &mut ctx.accounts.restaurante;
        restaurante.owner = ctx.accounts.owner.key();
        restaurante.nombre = nombre;
        restaurante.tipo_comida = tipo_comida;
        restaurante.ubicacion = ubicacion;
        restaurante.calificacion = calificacion;
        restaurante.precio_promedio = precio_promedio;
        msg!("Restaurante creado");
        Ok(())
    }

    pub fn read(ctx: Context<ReadRestaurante>) -> Result<()> {
        let r = &ctx.accounts.restaurante;
        msg!("Nombre: {}", r.nombre);
        msg!("Tipo: {}", r.tipo_comida);
        msg!("Ubicacion: {}", r.ubicacion);
        msg!("Calificacion: {}/10", r.calificacion);
        msg!("Precio: {}", r.precio_promedio);
        Ok(())
    }

    pub fn update(
        ctx: Context<UpdateRestaurante>,
        nombre: String,
        tipo_comida: String,
        ubicacion: String,
        calificacion: u8,
        precio_promedio: u32,
    ) -> Result<()> {
        let restaurante = &mut ctx.accounts.restaurante;
        restaurante.nombre = nombre;
        restaurante.tipo_comida = tipo_comida;
        restaurante.ubicacion = ubicacion;
        restaurante.calificacion = calificacion;
        restaurante.precio_promedio = precio_promedio;
        msg!("Restaurante actualizado");
        Ok(())
    }

    pub fn delete(_ctx: Context<DeleteRestaurante>) -> Result<()> {
        msg!("Restaurante eliminado");
        Ok(())
    }
}

#[derive(Accounts)]
pub struct CreateRestaurante<'info> {
    #[account(init, payer = owner, space = 300)]
    pub restaurante: Account<'info, Restaurante>,
    #[account(mut)]
    pub owner: Signer<'info>,
    pub system_program: Program<'info, System>,
}

#[derive(Accounts)]
pub struct ReadRestaurante<'info> {
    pub restaurante: Account<'info, Restaurante>,
}

#[derive(Accounts)]
pub struct UpdateRestaurante<'info> {
    #[account(mut, has_one = owner)]
    pub restaurante: Account<'info, Restaurante>,
    pub owner: Signer<'info>,
}

#[derive(Accounts)]
pub struct DeleteRestaurante<'info> {
    #[account(mut, has_one = owner, close = owner)]
    pub restaurante: Account<'info, Restaurante>,
    #[account(mut)]
    pub owner: Signer<'info>,
}

#[account]
pub struct Restaurante {
    pub owner: Pubkey,
    pub nombre: String,
    pub tipo_comida: String,
    pub ubicacion: String,
    pub calificacion: u8,
    pub precio_promedio: u32,
}

#[error_code]
pub enum ErrorRestaurante {
    #[msg("No autorizado")]
    NoAutorizado,
}
